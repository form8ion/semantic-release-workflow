{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>form8ion/renovate-config"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update semantic-release version used by npx",
      "fileMatch": [
        "^\\.github/workflows/release\\.yml$",
        "^\\.github/workflows/workflow-release\\.yml$"
      ],
      "matchStrings": [
        "\\srun: npx semantic-release@(?<currentValue>.*?)\\s"
      ],
      "datasourceTemplate": "npm",
      "depNameTemplate": "semantic-release"
    }
  ],
  "packageRules": [
    {
      "matchFileNames": [".github/workflows/release.yml"],
      "semanticCommitType": "fix"
    },
    {
      "matchFileNames": [".github/workflows/release.yml"],
      "matchUpdateTypes": ["major"],
      "commitBody": "BREAKING CHANGE: {{depName}} updated to v{{newMajor}}",
      "automerge": false
    }
  ]
}